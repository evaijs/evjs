{
  "name": "@evai/webpack-plugin",
  "version": "0.0.1",
  "description": "Webpack plugin and loaders for the evai framework",
  "type": "module",
  "main": "./esm/index.js",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "require": "./esm/index.js"
    },
    "./server-fn-loader": {
      "types": "./esm/server-fn-loader.d.ts",
      "default": "./esm/server-fn-loader.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit"
  },
  "keywords": [
    "evai",
    "webpack",
    "plugin",
    "loader"
  ],
  "author": "xusd320",
  "license": "MIT",
  "dependencies": {
    "@swc/core": "^1.15.18"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "webpack": "^5.105.4"
  }
}
