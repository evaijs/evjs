{
  "name": "@evjs/webpack-plugin",
  "version": "0.0.1-rc.9",
  "description": "Webpack plugin and loaders for the ev framework",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./esm/index.js",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "require": "./esm/index.js"
    },
    "./server-fn-loader": {
      "types": "./esm/server-fn-loader.d.ts",
      "default": "./esm/server-fn-loader.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "esm",
    "AGENT.md"
  ],
  "keywords": [
    "evjs",
    "webpack",
    "plugin",
    "loader",
    "server-functions"
  ],
  "author": "xusd320",
  "license": "MIT",
  "dependencies": {
    "@evjs/build-tools": "0.0.1-rc.8",
    "@evjs/manifest": "0.0.1-rc.8"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "webpack": "^5.105.4"
  },
  "homepage": "https://github.com/evaijs/evjs#readme",
  "bugs": {
    "url": "https://github.com/evaijs/evjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evaijs/evjs.git"
  }
}
