{
  "name": "@evjs/create-app",
  "version": "0.0.0",
  "description": "Scaffold a new evjs project",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "create-evjs-app": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "prepack": "node scripts/deref-templates.js",
    "postpack": "node scripts/restore-templates.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/prompts": "^2.4.9",
    "typescript": "^6.0.2"
  },
  "homepage": "https://github.com/evaijs/evjs#readme",
  "bugs": {
    "url": "https://github.com/evaijs/evjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evaijs/evjs.git"
  },
  "keywords": [
    "evjs",
    "create-app",
    "scaffolding",
    "react",
    "server-functions",
    "typescript",
    "framework"
  ],
  "license": "MIT",
  "author": "xusd320"
}
