{
  "name": "@evjs/build-tools",
  "version": "0.0.1-rc.4",
  "description": "Bundler-agnostic build utilities for the ev framework",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./esm/index.js",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "esm",
    "AGENT.md"
  ],
  "keywords": [
    "ev",
    "build",
    "server-functions"
  ],
  "author": "xusd320",
  "license": "MIT",
  "dependencies": {
    "@swc/core": "^1.15.18"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "homepage": "https://github.com/evaijs/evjs#readme",
  "bugs": {
    "url": "https://github.com/evaijs/evjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evaijs/evjs.git"
  }
}
