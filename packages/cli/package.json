{
  "name": "@evjs/cli",
  "version": "0.0.1-rc.10",
  "description": "CLI and configuration layer for the evjs framework",
  "type": "module",
  "main": "./dist/config.js",
  "types": "./dist/config.d.ts",
  "exports": {
    ".": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ev": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "AGENT.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "node ../../scripts/sync-versions.js && npm run build && node scripts/deref-templates.js",
    "postpublish": "node scripts/restore-templates.js"
  },
  "dependencies": {
    "@evjs/webpack-plugin": "0.0.1-rc.10",
    "@logtape/logtape": "^2.0.4",
    "@swc/core": "^1.2.147",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "fs-extra": "^11.3.0",
    "glob": "^13.0.6",
    "html-webpack-plugin": "^5.6.6",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "swc-loader": "^0.2.7",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.5",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.7.3"
  },
  "homepage": "https://github.com/evaijs/evjs#readme",
  "bugs": {
    "url": "https://github.com/evaijs/evjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evaijs/evjs.git"
  },
  "keywords": [
    "evjs",
    "cli",
    "react",
    "server-functions",
    "scaffolding",
    "dev-server",
    "typescript",
    "full-stack",
    "framework"
  ],
  "license": "MIT",
  "author": "xusd320"
}
