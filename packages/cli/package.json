{
  "name": "@evjs/cli",
  "version": "0.0.0",
  "description": "CLI and configuration layer for the evjs framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ev": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@evjs/webpack-plugin": "*",
    "@logtape/logtape": "^2.0.4",
    "@swc/core": "^1.15.21",
    "commander": "^12.1.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "html-webpack-plugin": "^5.6.6",
    "picocolors": "^1.1.1",
    "swc-loader": "^0.2.7",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.19.15",
    "typescript": "^6.0.2"
  },
  "homepage": "https://github.com/evaijs/evjs#readme",
  "bugs": {
    "url": "https://github.com/evaijs/evjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evaijs/evjs.git"
  },
  "keywords": [
    "evjs",
    "cli",
    "react",
    "server-functions",
    "scaffolding",
    "dev-server",
    "typescript",
    "full-stack",
    "framework"
  ],
  "license": "MIT",
  "author": "xusd320"
}
