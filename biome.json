{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "formatWithErrors": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useBlockStatements": "off",
        "useImportType": "warn",
        "noNamespace": "warn",
        "useNodejsImportProtocol": "error",
        "useConst": "error",
        "useExportType": "warn",
        "noNonNullAssertion": "warn",
        "useEnumInitializers": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "warn",
        "noConsole": "warn",
        "noDoubleEquals": "error"
      },
      "performance": {
        "noBarrelFile": "off",
        "noReExportAll": "error"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn"
      },
      "complexity": {
        "noForEach": "warn",
        "useFlatMap": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "e2e/**",
        "examples/**",
        "scripts/**",
        "packages/cli/**",
        "packages/shared/**",
        "packages/client/**",
        "packages/server/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "arrowParentheses": "always",
      "trailingCommas": "all"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
