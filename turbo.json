{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "esm/**"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "tsconfig.json"
      ]
    },
    "lint": {
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "package.json"
      ]
    },
    "release": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}