{
  "name": "@evjs/webpack-plugin",
  "version": "0.0.1-alpha.7",
  "description": "Webpack plugin and loaders for the ev framework",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./esm/index.js",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "require": "./esm/index.js"
    },
    "./server-fn-loader": {
      "types": "./esm/server-fn-loader.d.ts",
      "default": "./esm/server-fn-loader.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "esm"
  ],
  "keywords": [
    "ev",
    "webpack",
    "plugin",
    "loader"
  ],
  "author": "xusd320",
  "license": "MIT",
  "dependencies": {
    "@evjs/build-tools": "0.0.1-alpha.7",
    "@evjs/manifest": "0.0.1-alpha.7"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "webpack": "^5.105.4"
  }
}
