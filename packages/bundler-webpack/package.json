{
  "name": "@evjs/bundler-webpack",
  "version": "0.0.0",
  "description": "Webpack bundler adapter for the evjs framework",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./esm/index.js",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "require": "./esm/index.js"
    },
    "./server-fn-loader": {
      "types": "./esm/server-fn-loader.d.ts",
      "default": "./esm/server-fn-loader.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "check-types": "tsc --noEmit"
  },
  "files": [
    "esm"
  ],
  "keywords": [
    "evjs",
    "webpack",
    "plugin",
    "loader",
    "server-functions"
  ],
  "author": "xusd320",
  "license": "MIT",
  "dependencies": {
    "@evjs/build-tools": "*",
    "@evjs/manifest": "*",
    "@evjs/shared": "*",
    "@logtape/logtape": "^2.0.4",
    "@swc/core": "^1.15.21",
    "html-webpack-plugin": "^5.6.6",
    "swc-loader": "^0.2.7",
    "webpack": "^5.105.4",
    "webpack-dev-server": "^5.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^6.0.2"
  },
  "homepage": "https://github.com/evaijs/evjs#readme",
  "bugs": {
    "url": "https://github.com/evaijs/evjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evaijs/evjs.git"
  }
}
