{
  "name": "@evjs/build-tools",
  "version": "0.0.0",
  "description": "Bundler-agnostic build utilities for the ev framework",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./esm/index.js",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "check-types": "tsc --noEmit"
  },
  "files": [
    "esm"
  ],
  "keywords": [
    "evjs",
    "build-tools",
    "server-functions",
    "code-transform",
    "typescript"
  ],
  "author": "xusd320",
  "license": "MIT",
  "dependencies": {
    "@swc/core": "^1.15.21",
    "domparser-rs": "^0.0.7"
  },
  "devDependencies": {
    "@swc/types": "^0.1.25",
    "typescript": "^6.0.2"
  },
  "homepage": "https://github.com/evaijs/evjs#readme",
  "bugs": {
    "url": "https://github.com/evaijs/evjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evaijs/evjs.git"
  }
}
